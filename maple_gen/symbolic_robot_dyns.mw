</Input>
</Group>
<Group labelreference="L12" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">PiNames := [
    op(GeomNames),

    seq(cat(&quot;m&quot;,i), i=1..n),

    seq(cat(&quot;rcx&quot;,i), i=1..n),
    seq(cat(&quot;rcy&quot;,i), i=1..n),
    seq(cat(&quot;rcz&quot;,i), i=1..n),

    seq(cat(&quot;Ixx&quot;,i), i=1..n),
    seq(cat(&quot;Iyy&quot;,i), i=1..n),
    seq(cat(&quot;Izz&quot;,i), i=1..n),

    seq(cat(&quot;Ixy&quot;,i), i=1..n),
    seq(cat(&quot;Ixz&quot;,i), i=1..n),
    seq(cat(&quot;Iyz&quot;,i), i=1..n),

    &quot;g&quot;
]:

PiVec := Vector([seq(parse(PiNames[k]), k=1..nops(PiNames))]):

m  := Array(1..n):
rc := Array(1..n):
Ic := Array(1..n):

for i from 1 to n do
    m[i] := parse(cat(&quot;m&quot;, i)):

    rc[i] := Vector([
        parse(cat(&quot;rcx&quot;, i)),
        parse(cat(&quot;rcy&quot;, i)),
        parse(cat(&quot;rcz&quot;, i)),
        1
    ]):

    if useProductsOfInertia then
        Ic[i] := Matrix(3,3,[
            [parse(cat(&quot;Ixx&quot;,i)), parse(cat(&quot;Ixy&quot;,i)), parse(cat(&quot;Ixz&quot;,i))],
            [parse(cat(&quot;Ixy&quot;,i)), parse(cat(&quot;Iyy&quot;,i)), parse(cat(&quot;Iyz&quot;,i))],
            [parse(cat(&quot;Ixz&quot;,i)), parse(cat(&quot;Iyz&quot;,i)), parse(cat(&quot;Izz&quot;,i))]
        ]):
    else
        Ic[i] := DiagonalMatrix([
            parse(cat(&quot;Ixx&quot;,i)),
            parse(cat(&quot;Iyy&quot;,i)),
            parse(cat(&quot;Izz&quot;,i))
        ]):
    end if;
od:

g := parse(&quot;g&quot;):

PrintTitle(&quot;Geometry + dynamic parameters ready&quot;):
</Text-field>
</Input>
<Output><Text-field style="Line Printed Output" layout="Line Printed Output">==== Geometry + dynamic parameters ready ====
</Text-field>
</Output>
</Group>
<Group labelreference="L17" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">################################################################################
# 4) CRAIG MODIFIED DH TRANSFORM
################################################################################</Text-field>
</Input>
</Group>
<Group labelreference="L16" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">Amdh := proc(ai, alphai, di, thetai)
    local ct, st, ca, sa;
    ct := cos(thetai): st := sin(thetai):
    ca := cos(alphai): sa := sin(alphai):

    return Matrix(4,4,[
        [   ct,      -st,      0,      ai ],
        [ st*ca,   ct*ca,   -sa,   -di*sa ],
        [ st*sa,   ct*sa,    ca,    di*ca ],
        [    0,        0,     0,       1 ]
    ]);
end proc:</Text-field>
</Input>
</Group>
<Group labelreference="L19" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">################################################################################
# 5) ALL CUMULATIVE TRANSFORMS
################################################################################</Text-field>
</Input>
</Group>
<Group labelreference="L18" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">A := Array(1..n):
T := Array(0..n):

T[0] := Tbase:

for i from 1 to n do
    A[i] := Amdh(MDH[i,1], MDH[i,2], MDH[i,3], MDH[i,4]):
    T[i] := T[i-1] . A[i]:
od:

T0n := T[n]:
T0e := T0n . Ttool:
pe  := Vector([T0e[1,4], T0e[2,4], T0e[3,4]]):

PrintTitle(&quot;All cumulative transforms ready&quot;):</Text-field>
</Input>
<Output><Text-field style="Line Printed Output" layout="Line Printed Output">==== All cumulative transforms ready ====
</Text-field>
</Output>
</Group>
<Group labelreference="L21" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">################################################################################
# 6) EXTRACT FRAME ROTATIONS, ORIGINS, AXES
################################################################################</Text-field>
</Input>
</Group>
<Group labelreference="L20" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">Rot := Array(0..n):
p   := Array(0..n):
zv  := Array(0..n):

Rot[0] := Matrix(3,3,(r,c) -&gt; T[0][r,c]):
p[0]   := Vector([T[0][1,4], T[0][2,4], T[0][3,4]]):
zv[0]  := Vector([Rot[0][1,3], Rot[0][2,3], Rot[0][3,3]]):

for i from 1 to n do
    Rot[i] := Matrix(3,3,(r,c) -&gt; T[i][r,c]):
    p[i]   := Vector([T[i][1,4], T[i][2,4], T[i][3,4]]):
    zv[i]  := Vector([Rot[i][1,3], Rot[i][2,3], Rot[i][3,3]]):
od:

PrintTitle(&quot;Frame origins and z-axes extracted&quot;):</Text-field>
</Input>
<Output><Text-field style="Line Printed Output" layout="Line Printed Output">==== Frame origins and z-axes extracted ====
</Text-field>
</Output>
</Group>
<Group labelreference="L23" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">################################################################################
# 7) GENERAL GEOMETRIC JACOBIAN FOR CRAIG-MDH
################################################################################</Text-field>
</Input>
</Group>
<Group labelreference="L22" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">Jv := Matrix(3, n, 0):
Jw := Matrix(3, n, 0):

for i from 1 to n do
    if jointType[i] = &quot;R&quot; then
        Jv[1..3, i] := CrossProduct(zv[i], pe - p[i]);
        Jw[1..3, i] := zv[i];
    elif jointType[i] = &quot;P&quot; then
        Jv[1..3, i] := zv[i];
        Jw[1..3, i] := Vector([0,0,0]);
    else
<Font encoding="UTF-8">        error &quot;jointType[%1] must be \134&quot;R\134&quot; or \134&quot;P\134&quot;&quot;, i;
</Font>    end if;
od:

Jg := &lt; Jv ; Jw &gt;:

PrintTitle(&quot;General geometric Jacobian ready&quot;):</Text-field>
</Input>
<Output><Text-field style="Line Printed Output" layout="Line Printed Output">==== General geometric Jacobian ready ====
</Text-field>
</Output>
</Group>
<Group labelreference="L25" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">################################################################################
# 8) COM POSITIONS AND GENERAL COM JACOBIANS
################################################################################</Text-field>
</Input>
</Group>
<Group labelreference="L24" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">pc  := Array(1..n):
Jvc := Array(1..n):
Jwc := Array(1..n):

for i from 1 to n do
    pc[i] := Vector([
        add(T[i][1,k]*rc[i][k], k=1..4),
        add(T[i][2,k]*rc[i][k], k=1..4),
        add(T[i][3,k]*rc[i][k], k=1..4)
    ]):
od:

for ell from 1 to n do
    Jvc[ell] := Matrix(3, n, 0):
    Jwc[ell] := Matrix(3, n, 0):

    for j from 1 to n do
        if j &lt;= ell then
            if jointType[j] = &quot;R&quot; then
                Jvc[ell][1..3, j] := CrossProduct(zv[j], pc[ell] - p[j]);
                Jwc[ell][1..3, j] := zv[j];
            elif jointType[j] = &quot;P&quot; then
                Jvc[ell][1..3, j] := zv[j];
                Jwc[ell][1..3, j] := Vector([0,0,0]);
            else
<Font encoding="UTF-8">                error &quot;jointType[%1] must be \134&quot;R\134&quot; or \134&quot;P\134&quot;&quot;, j;
</Font>            end if;
        end if;
    od:
od:

PrintTitle(&quot;General COM Jacobians ready&quot;):</Text-field>
</Input>
<Output><Text-field style="Line Printed Output" layout="Line Printed Output">==== General COM Jacobians ready ====
</Text-field>
</Output>
</Group>
<Group labelreference="L27" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field style="Text" layout="Normal">################################################################################
# 9) DYNAMICS: M(q), C(q,dq), G(q), h(q,dq)=C(q,dq)*dq
################################################################################</Text-field>
</Input>
</Group>
<Group labelreference="L26" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">Mq := Matrix(n, n, 0):

for i from 1 to n do
    Mq := Mq
        + Transpose(Jvc[i]) . (m[i] * Jvc[i])
        + Transpose(Jwc[i]) . Rot[i] . Ic[i] . Transpose(Rot[i]) . Jwc[i];
od:

g0 := Vector([0, 0, g]):

P := 0:
for i from 1 to n do
    P := P + m[i] * DotProduct(g0, pc[i]);
od:

Gq := Vector([seq(diff(P, q[i]), i=1..n)]):

Cq := Matrix(n, n, 0):

for k from 1 to n do
    for j from 1 to n do
        Cq[k,j] := add(
            (1/2) * (
                diff(Mq[k,j], q[i]) +
                diff(Mq[k,i], q[j]) -
                diff(Mq[i,j], q[k])
            ) * dq[i],
            i = 1..n
        );
    od:
od:

hq := Cq . dq:

tau_id := Mq . ddq + Cq . dq + Gq:

PrintTitle(&quot;M(q), C(q,dq), G(q), h(q,dq), inverse dynamics ready&quot;):</Text-field>
</Input>
<Output><Text-field style="Line Printed Output" layout="Line Printed Output">==== M(q), C(q,dq), G(q), h(q,dq), inverse dynamics ready ====
</Text-field>
</Output>
</Group>
