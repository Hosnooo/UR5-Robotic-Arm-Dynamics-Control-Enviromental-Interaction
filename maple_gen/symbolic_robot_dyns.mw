<Group labelreference="L7" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">PrintTitle := proc(s::string)
<Font encoding="UTF-8">    printf(&quot;==== %s ====\134n&quot;, s);
</Font>end proc:

WriteTextFile := proc(fname::string, txt::string)
    local fd;
    fd := fopen(fname, WRITE, TEXT):
    fprintf(fd, &quot;%s&quot;, txt):
    fclose(fd):
end proc:

MatlabAssignScalar := proc(lhs::string, expr)
    local rhs;
    rhs := CodeGeneration:-Matlab(expr, output=string):
    rhs := StringTools:-RegSubs(&quot;^[[:space:]]*cg[0-9]*[[:space:]]*=[[:space:]]*&quot; = &quot;&quot;, rhs):
    rhs := StringTools:-RegSubs(&quot;;[[:space:]]*$&quot; = &quot;&quot;, rhs):
    return cat(lhs, &quot; = &quot;, rhs, &quot;;&quot;);
end proc:

MatlabAssignMatrix := proc(varname::string, A)
    local i, j, mA, nA, cs, nm, rhs, s;

    mA := RowDimension(A):
    nA := ColumnDimension(A):

    cs := []:
    for i from 1 to mA do
        for j from 1 to nA do
            nm := parse(cat(varname, &quot;_&quot;, convert(i,string), &quot;_&quot;, convert(j,string))):
            cs := [op(cs), nm = A[i,j]]:
        od:
    od:

    rhs := CodeGeneration:-Matlab(cs, optimize=tryhard, output=string):

    s := rhs:
<Font encoding="UTF-8">    s := cat(s, &quot;\134n&quot;, varname, &quot; = [&quot;);
</Font>    for i from 1 to mA do
        for j from 1 to nA do
            s := cat(s, varname, &quot;_&quot;, i, &quot;_&quot;, j);
            if j &lt; nA then
                s := cat(s, &quot;, &quot;);
            end if:
        od:
        if i &lt; mA then
            s := cat(s, &quot;; &quot;);
        end if:
    od:
    s := cat(s, &quot;];&quot;);

    return s:
end proc:

MatlabAssignVector := proc(varname::string, V)
    local i, nV, cs, nm, rhs, s;

    nV := Dimension(V):

    cs := []:
    for i from 1 to nV do
        nm := parse(cat(varname, &quot;_&quot;, convert(i,string))):
        cs := [op(cs), nm = V[i]]:
    od:

    rhs := CodeGeneration:-Matlab(cs, optimize=tryhard, output=string):

    s := rhs:
<Font encoding="UTF-8">    s := cat(s, &quot;\134n&quot;, varname, &quot; = [&quot;);
</Font>    for i from 1 to nV do
        s := cat(s, varname, &quot;_&quot;, i);
        if i &lt; nV then
            s := cat(s, &quot;; &quot;);
        end if:
    od:
    s := cat(s, &quot;];&quot;);

    return s:
end proc:

MakeUnpackQ := proc(n::posint)
    local i, s;
    s := &quot;&quot;;
    for i from 1 to n do
<Font encoding="UTF-8">        s := cat(s, &quot;q&quot;, i, &quot; = q(&quot;, i, &quot;);\134n&quot;);
</Font>    od:
    return s:
end proc:

MakeUnpackDQ := proc(n::posint)
    local i, s;
    s := &quot;&quot;;
    for i from 1 to n do
<Font encoding="UTF-8">        s := cat(s, &quot;dq&quot;, i, &quot; = dq(&quot;, i, &quot;);\134n&quot;);
</Font>    od:
    return s:
end proc:

MakeUnpackDDQ := proc(n::posint)
    local i, s;
    s := &quot;&quot;;
    for i from 1 to n do
<Font encoding="UTF-8">        s := cat(s, &quot;ddq&quot;, i, &quot; = ddq(&quot;, i, &quot;);\134n&quot;);
</Font>    od:
    return s:
end proc:

MakeUnpackPi := proc(PiNames::list)
    local k, s;
    s := &quot;&quot;;
    for k from 1 to nops(PiNames) do
<Font encoding="UTF-8">        s := cat(s, PiNames[k], &quot; = Pi(&quot;, k, &quot;);\134n&quot;);
</Font>    od:
    return s:
end proc:

WriteMatlabFunction := proc(fname::string, header::string, unpack::string, body::string)
    local txt;
<Font encoding="UTF-8">    txt := cat(&quot;function &quot;, header, &quot;\134n&quot;, unpack, body, &quot;end\134n&quot;);
</Font>    WriteTextFile(fname, txt):
end proc:</Text-field>
