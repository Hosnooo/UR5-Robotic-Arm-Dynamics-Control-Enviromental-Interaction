# ---------- wrappers ----------
WriteTextFile(
    fname_idyn,
    cat(
<Font encoding="UTF-8">        &quot;function tau = &quot;, robotName, &quot;_idyn(q,dq,ddq,Pi)\134n&quot;,
        &quot;M = &quot;, robotName, &quot;_M(q,Pi);\134n&quot;,
